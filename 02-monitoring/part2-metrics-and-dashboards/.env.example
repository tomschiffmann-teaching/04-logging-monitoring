# Optional email alerting (README step 6).
# Copy this file to `.env`, fill in your own mail account, then:
#   docker compose up -d grafana
#
# For Gmail you need an *app password* (NOT your normal password):
#   Google Account -> Security -> 2-Step Verification -> App passwords.
# Any other provider works too — just set its SMTP host:port and credentials.

SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-character-app-password
